---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Page not found">
  <div class="min-h-screen">
    <h1 class="text-4xl md:text-6xl tracking-wide font-normal md:font-normal mb-4 text-gray-700">
      Page not found
    </h1>
    <p class="mt-4 text-gray-600">
      The page you are looking for does not exist anymore, on never existed.
    </p>

    <p class="mt-4 hover:underline text-purple-600">
      <a href="/">Go to home page →</a>
    </p>
  </div>
</BaseLayout>
